{
  "name": "SendIn",
  "description": "Schedule LinkedIn outreach.",
  "version": "1.0.0",
  "manifest_version": 3,

  "action": {
    "default_title": "SendIn",
    "default_popup": "index.html"
  },

  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "http://localhost:8080/*",
    "http://localhost:8000/*",
    "https://api.sendin.app/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["timezone.js", "schedule.js"]
    }
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "192": "logo192.png",
    "512": "logo512.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}